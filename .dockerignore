public/hls/
public/assets/
public/.well-known/

# Temporary React dev files
*.local
*.cache
.cache/
.eslintcache
.stylelintcache
.storybook/

# CRA (if components existed earlier)
.env.development.local
.env.test.local
.env.production.local
.env


